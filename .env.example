# =============================================================================
# TIGI — Environment Configuration Template
# Copy to .env.local for local development. NEVER commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="TIGI"

# -----------------------------------------------------------------------------
# Auth (NextAuth v5 / Auth.js)
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Database (PostgreSQL via Prisma)
# Local: postgresql://postgres:password@localhost:5432/tigi_dev
# Railway: provided automatically
# -----------------------------------------------------------------------------
DATABASE_URL=""

# -----------------------------------------------------------------------------
# Redis (sessions, rate limits, AI cache)
# Local: redis://localhost:6379
# Upstash: provided in dashboard
# -----------------------------------------------------------------------------
REDIS_URL=""
REDIS_TOKEN=""

# -----------------------------------------------------------------------------
# Solana
# Network: devnet | mainnet-beta
# RPC: Helius (https://helius.dev) or public fallback
# -----------------------------------------------------------------------------
SOLANA_NETWORK="devnet"
SOLANA_RPC_URL=""                        # Server-side RPC (Helius or public)
NEXT_PUBLIC_SOLANA_NETWORK="devnet"
NEXT_PUBLIC_SOLANA_RPC_URL=""            # Client-side RPC for wallet adapter
# WARNING: Encrypt this secret — never expose it. Used for custodial wallets.
PLATFORM_WALLET_SECRET=""

# -----------------------------------------------------------------------------
# AI Provider
# Provider: mock | openai | anthropic
# 'mock' is the default for MVP — no API calls, deterministic responses
# -----------------------------------------------------------------------------
AI_PROVIDER="mock"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# -----------------------------------------------------------------------------
# File Storage (Cloudflare R2 or AWS S3)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER="r2"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="tigi-storage"
R2_PUBLIC_URL=""

# AWS S3 (alternative)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"
# S3_BUCKET=""

# -----------------------------------------------------------------------------
# Email (Resend — https://resend.com)
# In local dev, emails are logged to console unless RESEND_API_KEY is set
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="noreply@tigi.com"

# -----------------------------------------------------------------------------
# KYC/AML Provider
# Provider: mock | sumsub | onfido
# 'mock' auto-approves all submissions — production uses real provider
# -----------------------------------------------------------------------------
KYC_PROVIDER="mock"
SUMSUB_API_KEY=""
SUMSUB_SECRET_KEY=""

# -----------------------------------------------------------------------------
# Feature Flags
# Override defaults for local development
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_WALLET_CONNECT="true"
NEXT_PUBLIC_ENABLE_AI_FEATURES="false"
NEXT_PUBLIC_MAINTENANCE_MODE="false"
