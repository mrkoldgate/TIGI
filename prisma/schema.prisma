// =============================================================================
// TIGI — Prisma Schema
// Source of truth for all business data.
// See system-architecture.md §2.3 for full schema strategy.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// IDENTITY
// =============================================================================

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  emailVerified   DateTime?
  name            String?
  avatarUrl       String?
  phone           String?

  // Auth
  passwordHash    String?

  // RBAC — coarse access-control role
  role            UserRole @default(INVESTOR)

  // Onboarding — granular user-facing type + progress
  userType        UserType?            // selected during onboarding step 1
  onboardingStep  Int      @default(0) // 0=new, 1=role, 2=profile, 3=interests, 4=complete

  // Extended profile (set during onboarding steps 2–3)
  location        String?              // e.g. "Austin, TX"
  bio             String?  @db.Text
  preferences     Json?                // interests/goals — typed as UserPreferences in TS

  // Blockchain
  walletAddress   String?  // Public key of custodial or connected wallet

  // KYC
  kycStatus       KycStatus @default(NONE)

  // Subscription
  subscriptionTier SubscriptionTier @default(free)
  subscriptionEndsAt DateTime?

  // Relations
  accounts        Account[]
  sessions        Session[]
  custodialWallet CustodialWallet?
  properties      Property[]       @relation("PropertyOwner")
  tokenHoldings   TokenHolding[]
  transactions    Transaction[]    @relation("TransactionBuyer")
  kycVerifications KycVerification[]
  auditLogs       AuditLog[]
  savedListings   SavedListing[]
  userDocuments   UserDocument[]
  beneficiaryDesignations BeneficiaryDesignation[]
  intents         TransactionIntent[]
  legacyPlan      LegacyPlan?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Custodial wallet — separate table, restricted access
model CustodialWallet {
  id               String   @id @default(cuid())
  userId           String   @unique
  publicKey        String   @unique
  encryptedSecretKey String  @db.Text
  algorithm        String   @default("AES-256-GCM")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("custodial_wallets")
}

// =============================================================================
// PROPERTY
// =============================================================================

model Property {
  id          String        @id @default(cuid())
  ownerId     String
  title       String
  description String        @db.Text
  type        PropertyType
  status      ListingStatus @default(DRAFT)

  // Listing configuration
  listingType  ListingType   @default(BUY)
  ownershipModel OwnershipModel @default(FULL)

  // Location
  address     String
  city        String
  state       String
  country     String        @default("US")
  zipCode     String?
  latitude    Float?
  longitude   Float?

  // Specs
  price              Decimal?  @db.Decimal(14, 2)
  leaseRateMonthly   Decimal?  @db.Decimal(12, 2)
  sqft               Int?
  bedrooms           Int?
  bathrooms          Float?
  yearBuilt          Int?
  lotAcres           Float?
  parcelId           String?
  zoningCode         String?

  // Tokenization (denormalized for fast reads; authoritative record is Token table)
  isTokenized      Boolean  @default(false)
  tokenMintAddress String?

  // Features / keywords — JSON string array used for search and AI matching
  features         Json     @default("[]")

  // Engagement (incremented by background jobs / API handlers)
  viewCount    Int @default(0)
  saveCount    Int @default(0)
  inquiryCount Int @default(0)

  // Compliance review
  reviewNote  String?   @db.Text
  reviewedBy  String?
  reviewedAt  DateTime?
  featuredAt  DateTime?

  // Relations
  owner       User          @relation("PropertyOwner", fields: [ownerId], references: [id])
  images      PropertyImage[]
  documents   PropertyDocument[]
  token       Token?
  transactions Transaction[]
  aiValuations AiValuation[]
  intents      TransactionIntent[]
  leaseTerms   LeaseTerms?
  devOpportunity DevelopmentOpportunity?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  listedAt    DateTime?
  soldAt      DateTime?

  @@index([status, type, city])
  @@index([ownerId])
  @@index([price])
  @@map("properties")
}

model PropertyImage {
  id          String   @id @default(cuid())
  propertyId  String
  url         String
  storageKey  String?  // Path within storage bucket (e.g. "listing-images/{id}/{uuid}.jpg")
  fileName    String?  // Original uploaded file name
  fileSize    Int?     // Size in bytes
  mimeType    String?  // e.g. "image/jpeg"
  order       Int      @default(0)
  isPrimary   Boolean  @default(false)
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([propertyId, order])
  @@map("property_images")
}

model PropertyDocument {
  id          String       @id @default(cuid())
  propertyId  String
  name        String
  type        DocumentType
  url         String
  storageKey  String?      // Path within storage bucket
  fileName    String?      // Original uploaded file name
  fileSize    Int?         // Size in bytes
  mimeType    String?      // e.g. "application/pdf"
  verified    Boolean      @default(false)
  uploadedBy  String?      // userId of the uploader
  property    Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt   DateTime     @default(now())

  @@index([propertyId])
  @@map("property_documents")
}

// =============================================================================
// BLOCKCHAIN / TOKENIZATION
// =============================================================================

model Token {
  id              String   @id @default(cuid())
  propertyId      String   @unique
  mintAddress     String   @unique
  totalSupply     Int
  availableSupply Int
  pricePerFraction Decimal @db.Decimal(12, 2)
  status          TokenStatus @default(ACTIVE)
  metadataUri     String?

  property        Property @relation(fields: [propertyId], references: [id])
  holdings        TokenHolding[]

  mintedAt        DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("tokens")
}

model TokenHolding {
  id          String   @id @default(cuid())
  userId      String
  tokenId     String
  quantity    Int
  costBasis   Decimal  @db.Decimal(14, 2)

  user        User     @relation(fields: [userId], references: [id])
  token       Token    @relation(fields: [tokenId], references: [id])

  acquiredAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, tokenId])
  @@map("token_holdings")
}

// =============================================================================
// TRANSACTIONS
// =============================================================================

model Transaction {
  id              String            @id @default(cuid())
  buyerId         String
  propertyId      String
  type            TransactionType
  status          TransactionStatus @default(INITIATED)
  amount          Decimal           @db.Decimal(14, 2)
  fee             Decimal           @db.Decimal(14, 2)
  total           Decimal           @db.Decimal(14, 2)
  solanaSignature String?
  flagged         Boolean           @default(false)

  buyer           User              @relation("TransactionBuyer", fields: [buyerId], references: [id])
  property        Property          @relation(fields: [propertyId], references: [id])
  escrow          Escrow?
  steps           TransactionStep[]

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  completedAt     DateTime?

  @@map("transactions")
}

model TransactionStep {
  id            String   @id @default(cuid())
  transactionId String
  name          String
  completed     Boolean  @default(false)
  order         Int

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  completedAt   DateTime?
  createdAt     DateTime @default(now())

  @@map("transaction_steps")
}

model Escrow {
  id              String       @id @default(cuid())
  transactionId   String       @unique
  status          EscrowStatus @default(CREATED)
  amount          Decimal      @db.Decimal(14, 2)
  pdaAddress      String?      // Solana PDA address
  deadline        DateTime?

  transaction     Transaction  @relation(fields: [transactionId], references: [id])

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  fundedAt        DateTime?
  releasedAt      DateTime?

  @@map("escrows")
}

// =============================================================================
// COMPLIANCE
// =============================================================================

model KycVerification {
  id          String    @id @default(cuid())
  userId      String
  status      KycStatus @default(PENDING)
  provider    String    @default("mock")
  providerRef String?

  // Documents (S3 URLs — access-controlled)
  idFrontUrl  String?
  idBackUrl   String?
  selfieUrl   String?

  // Review
  reviewedBy  String?
  reviewNote  String?
  reviewedAt  DateTime?

  user        User      @relation(fields: [userId], references: [id])

  submittedAt DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("kyc_verifications")
}

// Append-only audit log — no UPDATE/DELETE allowed on this table
model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String   // e.g. "property.list", "kyc.approve", "token.mint"
  resourceType String? // e.g. "Property", "User", "Transaction"
  resourceId  String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?

  user        User?    @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

// =============================================================================
// SAVED LISTINGS
// =============================================================================

// User-linked bookmarks. listingId is not a FK to Property intentionally —
// allows referencing mock IDs during dev without constraint violations.
model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  savedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@map("saved_listings")
}

// =============================================================================
// USER DOCUMENTS
// =============================================================================

// Non-property documents: KYC identity docs, inheritance supporting docs, etc.
// Separate from PropertyDocument because these belong to the user, not a listing.
model UserDocument {
  id          String         @id @default(cuid())
  userId      String
  purpose     UserDocPurpose
  name        String
  url         String
  storageKey  String?        // Path within storage bucket
  fileName    String?        // Original uploaded file name
  fileSize    Int?           // Size in bytes
  mimeType    String?        // e.g. "application/pdf"
  verified    Boolean        @default(false)
  reviewedBy  String?
  reviewNote  String?

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId, purpose])
  @@map("user_documents")
}

// =============================================================================
// TERRA — Land Leasing & Development
// =============================================================================
//
// LeaseTerms:           Structured lease configuration for a land parcel.
//                       One-to-one with Property. Separate model so terms can
//                       be updated independently of core listing data.
//
// DevelopmentOpportunity: Structured development signals for a land parcel.
//                         Replaces / formalizes the inferred feature-array
//                         approach used in M2. Powers the Terra dev filter.
// =============================================================================

model LeaseTerms {
  id              String             @id @default(cuid())
  propertyId      String             @unique

  // Duration
  durationType    LeaseDurationType  @default(NEGOTIABLE)
  minimumMonths   Int?               // minimum lease term required
  maximumMonths   Int?               // maximum term offered (null = open-ended)

  // Financials
  rateMonthly     Decimal?           @db.Decimal(14, 2)
  rateAnnual      Decimal?           @db.Decimal(14, 2)
  ratePerAcre     Decimal?           @db.Decimal(14, 2)  // $/acre/year
  securityDeposit Decimal?           @db.Decimal(14, 2)

  // Escalation
  escalationType  LeaseEscalationType @default(NONE)
  escalationRate  Float?              // percent per year (if PERCENT_PER_YEAR)

  // Option clauses
  hasRenewalOption     Boolean  @default(false)
  renewalTermMonths    Int?
  hasPurchaseOption    Boolean  @default(false)
  purchaseOptionPrice  Decimal? @db.Decimal(14, 2)

  // Permitted / restricted uses — JSON string arrays
  allowedUses     Json     @default("[]")
  prohibitedUses  Json     @default("[]")

  // Free-text additional terms
  additionalTerms String?  @db.Text

  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("lease_terms")
}

model DevelopmentOpportunity {
  id          String           @id @default(cuid())
  propertyId  String           @unique

  stage       DevelopmentStage @default(RAW)

  // Zoning
  zoningDescription   String?  @db.Text
  maxBuildableUnits   Int?
  maxFloorAreaRatio   Float?
  heightLimitFt       Int?

  // Infrastructure
  utilitiesAvailable  Json     @default("[]")  // string array of utility types
  roadAccess          Boolean  @default(false)
  roadType            String?  // "Paved", "Gravel", "Easement"

  // Entitlements
  entitlementStatus   String?  // "Unentitled" | "In process" | "Entitled"
  permitsAvailable    Json     @default("[]")  // string array of permit names
  environmentalStatus String?  // "Clean" | "Phase I complete" | "Remediation needed"

  // Topography
  topography          String?  // "Flat" | "Gently sloping" | "Rolling" | "Hilly"
  floodZone           String?  // "None" | "Zone X" | "Zone AE"

  // Dev highlights — string array shown as bullet points
  highlights          Json     @default("[]")

  // Notes for future financing / crowdfunding
  financingNotes      String?  @db.Text

  property            Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("development_opportunities")
}

// =============================================================================
// INHERITANCE
// =============================================================================

model BeneficiaryDesignation {
  id                String          @id @default(cuid())
  userId            String
  tokenHoldingId    String
  beneficiaryEmail  String
  beneficiaryName   String?
  sharePercent      Int             // 1–100
  triggerType       TransferTrigger @default(MANUAL)
  triggerDate       DateTime?
  inactivityDays    Int?
  status            DesignationStatus @default(ACTIVE)

  user              User            @relation(fields: [userId], references: [id])

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  revokedAt         DateTime?

  @@map("beneficiary_designations")
}

// ---------------------------------------------------------------------------
// LegacyPlan — user's overall inheritance planning document.
//
// One plan per user (unique userId). Starts as DRAFT, user progresses
// through a wizard (onboardingStep tracks position), then SUBMITS for
// admin/compliance review. Admin can APPROVE (→ ACTIVE), REJECT, or
// REQUEST_UPDATE (→ back to DRAFT with reviewNote).
//
// This is a structured planning tool — NOT a final legal instrument.
// Language enforced via LEGACY_MESSAGING constants in legacy-query.ts.
// ---------------------------------------------------------------------------
model LegacyPlan {
  id             String          @id @default(cuid())
  userId         String          @unique

  status         LegacyPlanStatus @default(DRAFT)

  // Free-text planning fields
  instructions   String?         @db.Text  // General estate instructions
  specialConditions String?      @db.Text  // Any special distribution conditions

  // Executor (the person who will carry out the plan)
  executorName   String?
  executorEmail  String?
  executorPhone  String?

  // Wizard progress — 0=intro, 1=instructions, 2=beneficiaries, 3=executor, 4=documents, 5=review
  onboardingStep Int             @default(0)

  // Compliance review fields
  submittedAt    DateTime?
  reviewedAt     DateTime?
  reviewedBy     String?         // Admin user ID
  reviewNote     String?         @db.Text

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  beneficiaries  LegacyBeneficiary[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("legacy_plans")
}

// ---------------------------------------------------------------------------
// LegacyBeneficiary — person-level beneficiary on a LegacyPlan.
//
// allocationPercent is a target split — total across all beneficiaries
// should sum to 100. Enforced at the application layer, not DB constraint
// (allows partial / in-progress plans).
// ---------------------------------------------------------------------------
model LegacyBeneficiary {
  id                String                  @id @default(cuid())
  legacyPlanId      String

  name              String
  email             String?
  phone             String?
  relationship      BeneficiaryRelationship @default(OTHER)

  // Desired allocation percent (0–100). May not sum to 100 while editing.
  allocationPercent Int                     @default(0)

  notes             String?                 @db.Text

  plan              LegacyPlan              @relation(fields: [legacyPlanId], references: [id], onDelete: Cascade)

  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([legacyPlanId])
  @@map("legacy_beneficiaries")
}

// =============================================================================
// AI
// =============================================================================

model AiValuation {
  id               String   @id @default(cuid())
  propertyId       String
  estimatedValue   Decimal  @db.Decimal(14, 2)
  valueRangeLow    Decimal  @db.Decimal(14, 2)
  valueRangeHigh   Decimal  @db.Decimal(14, 2)
  confidenceScore  Float
  confidence       AiConfidence
  methodology      String   @db.Text
  provider         String   @default("mock")
  modelVersion     String?

  property         Property @relation(fields: [propertyId], references: [id])

  generatedAt      DateTime @default(now())

  @@map("ai_valuations")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  INVESTOR
  OWNER
  BOTH
  ADMIN
  COMPLIANCE_OFFICER
}

// Granular onboarding-selected role. Maps to UserRole for RBAC but stored
// separately for dashboard personalization and future feature gating.
enum UserType {
  BUYER
  INVESTOR
  SELLER
  PROPERTY_OWNER
  LAND_OWNER
  DEVELOPER
  LEGAL_PROFESSIONAL
  FINANCIAL_PROFESSIONAL
}

enum KycStatus {
  NONE
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

enum SubscriptionTier {
  free
  pro
  pro_plus
  enterprise
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  LAND
  INDUSTRIAL
  MIXED_USE
}

enum ListingStatus {
  DRAFT
  UNDER_REVIEW
  ACTIVE
  SOLD
  LEASED
  DELISTED
}

enum ListingType {
  BUY
  LEASE
  BOTH
}

enum OwnershipModel {
  FULL
  FRACTIONAL
  BOTH
}

enum DocumentType {
  TITLE_DEED
  INSPECTION
  APPRAISAL
  CONTRACT
  OFFERING
  OTHER
}

enum TokenStatus {
  PENDING
  ACTIVE
  FROZEN
  BURNED
}

enum TransactionType {
  FRACTIONAL_INVESTMENT
  FULL_PURCHASE
  LEASE
}

enum TransactionStatus {
  INITIATED
  OFFER_PENDING
  ESCROW_CREATED
  ESCROW_FUNDED
  CONDITIONS_MET
  COMPLETED
  FAILED
  CANCELLED
  DISPUTED
}

enum EscrowStatus {
  CREATED
  FUNDED
  RELEASED
  REFUNDED
  DISPUTED
  CANCELLED
}

enum TransferTrigger {
  MANUAL
  DATE
  INACTIVITY
}

enum DesignationStatus {
  ACTIVE
  REVOKED
}

enum LeaseDurationType {
  FIXED          // Set term (minimumMonths = maximumMonths)
  FLEXIBLE       // Range (minimumMonths to maximumMonths)
  MONTH_TO_MONTH
  NEGOTIABLE
}

enum LeaseEscalationType {
  NONE
  FIXED          // Fixed increase per renewal period
  CPI            // Consumer Price Index linked
  PERCENT_PER_YEAR
}

enum DevelopmentStage {
  RAW           // Unimproved, no entitlements
  ENTITLED      // Zoning and permits approved
  IMPROVED      // Infrastructure in place
  SHOVEL_READY  // All approvals + grading + utilities done
}

enum LegacyPlanStatus {
  DRAFT          // User still filling in / editing
  SUBMITTED      // Awaiting compliance review
  UNDER_REVIEW   // Compliance officer actively reviewing
  ACTIVE         // Approved — plan is on file
  SUSPENDED      // Temporarily suspended by admin
}

enum BeneficiaryRelationship {
  SPOUSE
  PARTNER
  CHILD
  SIBLING
  PARENT
  GRANDCHILD
  TRUSTEE
  CHARITY
  FRIEND
  OTHER
}

enum AiConfidence {
  LOW
  MEDIUM
  HIGH
}

enum UserDocPurpose {
  KYC          // Identity verification documents
  INHERITANCE  // Beneficiary designation supporting documents
  OTHER
}

// =============================================================================
// TRANSACTION INTENTS  (M3 — pre-execution layer)
// =============================================================================
//
// TransactionIntent captures user intent before full legal execution.
// Sits between "browsing" and a full Transaction — the lightweight first step.
//
// Lifecycle:  PENDING → REVIEWING → APPROVED → EXECUTED (→ Transaction row)
//             PENDING → CANCELLED (user withdrew)
//             PENDING / REVIEWING → EXPIRED (no action after expiresAt)
//
// Blockchain hook point: metadata JSON is populated by compliance checks and
// eventually Solana tx references when Milestone 5 smart contracts are ready.
// =============================================================================

enum IntentType {
  EXPRESS_INTEREST  // Soft signal — "I'm interested"
  PREPARE_PURCHASE  // Full-ownership purchase intent
  PREPARE_INVEST    // Fractional token investment intent
  PREPARE_LEASE     // Lease intent
}

enum IntentStatus {
  PENDING        // Created, awaiting compliance pre-check
  REVIEWING      // Compliance officer manually reviewing
  APPROVED       // Pre-approved, user may proceed to wallet preparation
  READY_TO_SIGN  // Solana tx prepared server-side, awaiting client wallet signature
  EXECUTED       // Signed tx confirmed on-chain; promoted to Transaction record
  CANCELLED      // Withdrawn by user (or admin-cancelled)
  EXPIRED        // Passed expiresAt without action
}

model TransactionIntent {
  id          String       @id @default(cuid())
  userId      String
  propertyId  String

  intentType  IntentType
  status      IntentStatus @default(PENDING)

  // Intent-specific numeric data
  fractionQty  Int?               // PREPARE_INVEST: desired fraction count
  offerAmount  Decimal?           @db.Decimal(14, 2) // PREPARE_PURCHASE: indicative offer

  // Free-text user context — stored in audit trail
  note         String?            @db.Text

  // Extensible hook point: populated by compliance checks, legal workflow,
  // Solana tx signatures, or external vendor callbacks (Milestone 5+)
  metadata     Json               @default("{}")

  // Set when this intent is promoted to a full on-chain / legal Transaction
  transactionId String?

  user         User               @relation(fields: [userId], references: [id])
  property     Property           @relation(fields: [propertyId], references: [id])

  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  expiresAt    DateTime?

  @@index([userId])
  @@index([propertyId])
  @@index([status])
  @@map("transaction_intents")
}
